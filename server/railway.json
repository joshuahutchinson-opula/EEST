{
  "services": {
    "frontend": {
      "build": {
        "builder": "nixpacks",
        "buildCommand": "npm run build"
      },
      "deploy": {
        "startCommand": "npm run start",
        "port": 3000
      }
    },
    "backend": {
      "build": {
        "builder": "nixpacks",
        "buildCommand": "cd server && npm ci && npm run build"
      },
      "deploy": {
        "startCommand": "cd server && npm start",
        "port": 3001
      }
    }
  }
}